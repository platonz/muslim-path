# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPA_URL=https://your-project-id.supabase.co
VITE_SUPA_ANON_KEY=your-anon-public-key

# ── Cloudflare Worker (upload proxy) ──────────────────────────────────────────
# The worker URL is safe to expose (VITE_ = visible in browser)
VITE_UPLOAD_WORKER_URL=https://uploadworker.your-subdomain.workers.dev

# ── Admin upload key (SERVER-SIDE ONLY — no VITE_ prefix) ────────────────────
# Set this in Vercel dashboard under Environment Variables (NOT prefixed with VITE_)
# Never put the real value here if you commit .env.example
UPLOAD_KEY=your-worker-admin-key
SUPA_URL=https://your-project-id.supabase.co
SUPA_ANON_KEY=your-anon-public-key
UPLOAD_WORKER_URL=https://uploadworker.your-subdomain.workers.dev
ADMIN_EMAILS=you@example.com
